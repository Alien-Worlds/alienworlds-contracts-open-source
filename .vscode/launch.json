{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run tests skip compile",
      "skipFiles": ["<node_internals>/**"],
      "program": "node_modules/lamington",
      "args": ["test", "-DIS_DEV", "--contracts", "competitions", "-s"],
      "outFiles": ["${workspaceFolder}/**/*.js"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Lamington Tests",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "sourceMaps": true,
      "smartStep": true,
      "protocol": "inspector"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Lamington Tests (Specific Contract)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "test", "-g", "Competitions", "s"],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen",
      "skipFiles": ["<node_internals>/**"],
      "outFiles": ["${workspaceFolder}/**/*.js"],
      "sourceMaps": true,
      "smartStep": true,
      "protocol": "inspector"
    }
  ]
}